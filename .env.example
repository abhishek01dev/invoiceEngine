# Application Settings
APP_NAME=Invoice OCR Parser Service
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# File Upload Settings
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png

# OCR Settings
TESSERACT_CMD=/usr/bin/tesseract
OCR_LANG=eng
OCR_DPI=300

# Processing Settings
MAX_WORKERS=2
PROCESSING_TIMEOUT=30